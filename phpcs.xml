<?xml version="1.0"?>
<ruleset
	name="Lime Product Labels"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd">

	<description>Lime Product Labels coding standards ruleset.</description>

	<!-- Include all files -->
	<file>.</file>

	<!-- Exclude paths -->
	<exclude-pattern>./tests/*</exclude-pattern>
	<exclude-pattern>./assets/*</exclude-pattern>
	<exclude-pattern>./build/*</exclude-pattern>
	<exclude-pattern>./node_modules/*</exclude-pattern>
	<exclude-pattern>./vendor/*</exclude-pattern>

	<!-- Scan args -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="parallel" value="50"/>
	<arg name="extensions" value="php"/>

	<!-- Configs -->
	<config name="testVersion" value="8.0-"/>
	<rule ref="PHPCompatibilityWP"/>
	<config name="minimum_supported_wp_version" value="5.0"/>

	<!-- Rules -->
	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<rule ref="WooCommerce-Core">
		<exclude name="Core.Commenting.CommentTags.AuthorTag"/>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array" value="limewoo, LimeProductLabels"/>
		</properties>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array" value="lime-product-labels"/>
		</properties>
	</rule>
</ruleset>
